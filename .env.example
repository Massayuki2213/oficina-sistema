# ==========================================================
# Hermes — variáveis de ambiente (copie para .env e ajuste)
# ==========================================================

# ---- Banco de dados (PostgreSQL) ----
# Local (docker-compose). Em produção, troque pela URL da nuvem (Supabase/Neon/Railway).
DATABASE_URL="postgresql://hermes:hermes_dev@localhost:5432/hermes?schema=public"

# ---- Cache (Redis) ----
REDIS_URL="redis://localhost:6379"

# ---- API ----
API_PORT=3333
API_HOST=0.0.0.0
NODE_ENV=development

# ---- Segurança / Login (JWT + perfis) ----
JWT_SECRET="troque-por-uma-chave-longa-e-secreta"
JWT_EXPIRES_IN="8h"
